  cursor:ew-resize;
  z-index:10;
}

.resize-handle.left{
  left:0;
}

.resize-handle.right{
  right:0;
}

/* 里程碑分界点 */
.milestone-divider{
  position:absolute;
  top:0;
  bottom:0;
  width:4px;
  cursor:ew-resize;
  z-index:8;
  transform:translateX(-2px);
  transition:width 0.2s, transform 0.2s;
}

.milestone-divider:hover{
  width:8px;
  transform:translateX(-4px);
}

.divider-handle{
  width:100%;
  height:100%;
  background:rgba(255,255,255,0.9);
  box-shadow:0 0 4px rgba(0,0,0,0.4);
  border-radius:2px;
  position:relative;
}

.divider-handle::before{
  content:'';
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  width:2px;
  height:60%;
  background:rgba(0,0,0,0.3);
}

.milestone-divider:hover .divider-handle{
  background:rgba(255,255,255,1);
  box-shadow:0 0 8px rgba(0,0,0,0.5);
}

/* 移除旧的里程碑标记样式 */
</style>
