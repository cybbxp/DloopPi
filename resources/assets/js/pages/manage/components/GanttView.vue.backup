  border-bottom:1px solid #eee;
}

.date-row:last-child{
  border-bottom:none;
}

.date-cell{
  flex-shrink:0;
  border-right:1px solid #eee;
  text-align:center;
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
  min-width:15px;
  cursor:pointer;
  transition:background-color 0.2s;
}

.date-cell:hover{
  background:#f5f5f5;
}

.date-cell.month-start{
  border-left:2px solid #1890ff;
}

.date-cell.today{
  background:#e6f7ff;
  font-weight:bold;
}

.date-cell.selected{
  background:#bae7ff;
}

.month-row .date-cell{
  font-size:12px;
  color:#1890ff;
  font-weight:bold;
  border-right:2px solid #1890ff;
}

.month-row .date-cell:last-child{
  border-right:1px solid #eee;
}

.month-cell{
  cursor:default !important;
}

.month-cell:hover{
  background:transparent !important;
}

.day-row .date-cell{
  font-size:14px;
  font-weight:bold;
}

.week-row .date-cell{
  font-size:10px;
  color:#999;
}

.year-content{
  flex:1;
  overflow:auto;
  position:relative;
}

.year-content::-webkit-scrollbar{
  width:8px;
  height:8px;
}

.year-content::-webkit-scrollbar-thumb{
  background:#ccc;
  border-radius:4px;
}

.project-row{
  position:absolute;
  left:0;
  right:0;
  display:flex;
}

.project-row-even .row-left{
  background:#f9f9f9;
}

.project-row-even .row-right{
  background:#fafafa;
}

.row-left{
  width:150px;
  flex-shrink:0;
  background:#fafafa;
  border-right:1px solid #ddd;
  border-bottom:2px solid #e0e0e0;
  padding:8px;
  position:sticky;
  left:0;
  z-index:10;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.row-right{
  flex:1;
  position:relative;
  overflow:hidden;
  border-bottom:2px solid #e0e0e0;
}

.drag-layer{
  position:absolute;
  top:0;
  left:0;
  height:100%;
  z-index:0;
  cursor:grab;
}

.drag-layer:active{
  cursor:grabbing;
}

.date-columns{
  position:absolute;
  top:0;
  left:0;
  height:100%;
  pointer-events:none;
  z-index:1;
}

.date-column{
  position:absolute;
  top:0;
  height:100%;
  border-right:1px solid #f0f0f0;
}

.date-column.today-column{
  background:rgba(24,144,255,0.05);
  border-right:1px solid rgba(24,144,255,0.2);
}

.date-column.selected-column{
  background:rgba(24,144,255,0.1);
  border-right:1px solid rgba(24,144,255,0.3);
}

.tasks-container{
  position:relative;
  height:100%;
  z-index:2;
}

/* 任务条包装器 */
.task-bar-wrapper{
  position:absolute;
  display:flex;
  align-items:stretch;
  cursor:move;
  transition:opacity 0.2s;
}

.task-bar-wrapper:hover{
  opacity:0.9;
