<template>
  <div class="calendar-year-view">

    <!-- ================== 顶部日期表头 ================== -->
    <div class="year-header">

      <!-- 左侧固定列 -->
      <div class="header-left">
        项目
      </div>

      <!-- 右侧日期滚动区 -->
      <div class="header-right">
        <div
          class="dates-scroll"
          ref="headerScroll"
        >
          <!-- 第一行：月份 -->
          <div class="date-row month-row">
            <div
              v-for="monthInfo in monthsInfo"
              :key="'month-' + monthInfo.month"
              class="date-cell month-cell"
              :class="{
                'today': visibleDays[monthInfo.startIndex] && visibleDays[monthInfo.startIndex].isToday
              }"
              :style="{ width: monthInfo.width + 'px', minWidth: monthInfo.width + 'px' }"
            >
              <span>{{ monthInfo.month }}月</span>
            </div>
          </div>

          <!-- 第二行：日期 -->
          <div class="date-row day-row">
            <div
              v-for="day in visibleDays"
              :key="'day-' + day.date"
              class="date-cell"
              :class="{
                'month-start': day.isMonthStart,
                'today': day.isToday,
                'selected': selectedDate === day.date
              }"
              :style="{ width: dayWidth + 'px' }"
              @click="selectDate(day.date)"
            >
              {{ day.day }}
            </div>
          </div>

          <!-- 第三行：星期 -->
          <div class="date-row week-row">
            <div
              v-for="day in visibleDays"
              :key="'week-' + day.date"
              class="date-cell"
              :class="{
                'month-start': day.isMonthStart,
                'today': day.isToday,
                'selected': selectedDate === day.date
              }"
              :style="{ width: dayWidth + 'px' }"
              @click="selectDate(day.date)"
            >
              {{ day.weekday }}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================== 主体内容 ================== -->
    <div
      class="year-content"
      ref="contentScroll"
      @scroll="onContentScroll"
    >

      <!-- 整体虚拟容器 -->
      <div
        :style="{
          height: totalHeight + 'px',
          position: 'relative',
          minWidth: totalWidth + 'px'
        }"
      >

        <!-- 仅渲染可视区域项目（虚拟滚动） -->
        <div
          v-for="(project, index) in visibleProjects"
          :key="project.id"
          class="project-row"
          :class="{ 'project-row-even': index % 2 === 0 }"
          :style="{
            top: project._top + 'px',
            height: project.height + 'px'
          }"
        >

          <!-- 左侧项目名（固定） -->
          <div class="row-left" @wheel.prevent="onLeftWheel">
            {{ project.name }}
          </div>

          <!-- 右侧任务时间轴 -->
          <div class="row-right" @wheel.prevent="onRightWheel">
            <!-- 背景层（用于接收拖拽事件） -->
            <div
              class="drag-layer"
              :style="{ width: totalWidth + 'px', minWidth: totalWidth + 'px' }"
              @mousedown="startViewDrag"
            ></div>

            <!-- 背景列（今天标记和选中状态） -->
            <div class="date-columns" :style="{ width: totalWidth + 'px', minWidth: totalWidth + 'px' }">
              <div
                v-for="day in visibleDays"
                :key="'col-' + day.date"
                class="date-column"
                :class="{
                  'today-column': day.isToday,
                  'selected-column': selectedDate === day.date
                }"
                :style="{ width: dayWidth + 'px', left: (day.index * dayWidth) + 'px' }"
              />
            </div>

            <div
              class="tasks-container"
              :style="{ width: totalWidth + 'px', minWidth: totalWidth + 'px' }"
              @mousedown="startViewDrag"
            >

              <!-- 任务条 -->
              <div
                v-for="task in project.flatTasks"
                :key="task._renderKey"
                class="task-bar-wrapper"
                :style="getTaskWrapperStyle(task)"
              >
                <!-- 左 resize 手柄 -->
                <div
                  class="resize-handle left"
                  @mousedown.stop="startResize(task,'left',$event)"
                />

                <!-- 分段任务条 -->
                <div
                  v-for="(segment, idx) in getTaskSegments(task)"
                  :key="`${task.id}-segment-${segment.startDate}-${segment.endDate}`"
                  class="task-bar-segment"
                  :class="{
                    'task-completed': task.complete_at,
                    'task-overdue': task.overdue && !task.complete_at,
                    'is-subtask': task._isSubtask
                  }"
                  :style="getSegmentStyle(segment)"
                  @mousedown="startDrag(task,$event)"
                >
                  <!-- 子任务展开按钮（仅第一段显示） -->
                  <span
                    v-if="idx === 0 && task._subCount > 0"
                    class="subtask-toggle"
                    @click.stop="toggleSubtasks(task)"
                  >
                    +{{ task._subCount }}
                  </span>

                  <!-- 任务标题（仅第一段显示） -->
                  <span v-if="idx === 0" class="task-title" @click.stop="openTask(task)">
                    {{ task.name }}
                  </span>

                  <!-- 里程碑名称（最后一天显示） -->
                  <span v-if="segment.milestone" class="milestone-label">
                    {{ segment.milestone.name }}
                  </span>
                </div>

                <!-- 里程碑分界点（可拖动） -->
                <div
                  v-for="(milestone, idx) in getMilestones(task)"
                  :key="`divider-${idx}`"
                  class="milestone-divider"
                  :style="getMilestoneDividerStyle(task, milestone)"
                  @mousedown.stop="startMilestoneDrag(task, idx, $event)"
                >
                  <div class="divider-handle"></div>
                </div>

                <!-- 右 resize 手柄 -->
                <div
                  class="resize-handle right"
                  @mousedown.stop="startResize(task,'right',$event)"
                />
              </div>

            </div>
          </div>

        </div>

      </div>
    </div>

  </div>
</template>

<script>
import { mapState } from "vuex"

export default {

  props:{ year:Number },

  data(){
    return{
      dayWidth:40,      // 单日宽度
      rowHeight:60,     // 单行高度

      scrollTop:0,      // 当前垂直滚动
      scrollLeft:0,     // 当前水平滚动

      expandedTasks: [], // 展开的任务ID数组
      selectedDate: null, // 选中的日期

      // 拖拽预览状态（避免直接修改 computed 结果）
      dragPreview: null, // { taskId, startOffset, duration }

      dragTask:null,
      resizeMode:null,
      dragStartX:0,
      originalStart:0,
      originalEnd:0,
      originalDuration:0,

      // 里程碑拖拽
      milestoneDragTask: null,
      milestoneDragIndex: null,
      milestoneDragStartX: 0,
      milestoneOriginalDate: null,

      // Final段配置
      finalSegmentColor: '#50E3C2', // Final段的颜色

      // 视图拖拽相关
      isDraggingView: false,
      viewDragStartX: 0,
      viewDragStartY: 0,
      viewScrollStartX: 0,
      viewScrollStartY: 0,
      viewDragVelocityX: 0,
      viewDragVelocityY: 0,
      viewDragLastX: 0,
      viewDragLastY: 0,
      viewDragLastTime: 0,
      inertiaAnimationId: null,

      syncingScroll: false // 防止滚动循环
    }
  },

  computed:{

    ...mapState(['cacheTasks','cacheProjects']),

    // 年起始时间
    yearStart(){
      return $A.dayjs(`${this.year}-01-01`).startOf('day')
    },

    yearEnd(){
      return $A.dayjs(`${this.year}-12-31`).endOf('day')
    },

    // 生成全年日期数组（三行：月份、日期、星期）
    visibleDays(){
      const arr=[]
      const total=this.yearEnd.diff(this.yearStart,'day')+1
      const today=$A.dayjs().format('YYYY-MM-DD')
      const weekdays = ['日', '一', '二', '三', '四', '五', '六']

      for(let i=0;i<total;i++){
        const d=this.yearStart.add(i,'day')
        arr.push({
          date:d.format('YYYY-MM-DD'),
          day:d.date(),
          month:d.month()+1,
          weekday:weekdays[d.day()],
          isMonthStart:d.date()===1,
          isToday:d.format('YYYY-MM-DD')===today,
          index:i  // 添加索引，避免后续 indexOf
        })
      }
      return arr
    },

    // 计算每个月的信息（用于合并单元格）
    monthsInfo(){
      const months = []
      let currentMonth = null
      let dayCount = 0
      let startIndex = 0

      this.visibleDays.forEach((day, index) => {
        if(day.month !== currentMonth){
          if(currentMonth !== null){
            months.push({
              month: currentMonth,
              dayCount: dayCount,
              startIndex: startIndex,
              width: dayCount * this.dayWidth
            })
          }
          currentMonth = day.month
          dayCount = 1
          startIndex = index
        }else{
          dayCount++
        }
      })

      // 添加最后一个月
      if(currentMonth !== null){
        months.push({
          month: currentMonth,
          dayCount: dayCount,
          startIndex: startIndex,
          width: dayCount * this.dayWidth
        })
      }

      return months
    },

    // 时间轴总宽度
    totalWidth(){
      return this.visibleDays.length*this.dayWidth
    },

    // 生成项目+任务结构（支持无限层级子任务展开/收起）
    projects(){

      const map=new Map()

      // 收集所有有效任务
      const validTasks = []
      this.cacheTasks.forEach(t=>{
        // 过滤：必须有结束时间，且在年度范围内
        if(!t.end_at) return
        if(t.archived_at) return // 过滤已归档

        const taskStart=$A.dayjs(t.start_at)
        const taskEnd=$A.dayjs(t.end_at)

        // 任务必须与年度范围有交集
        if(taskEnd.isBefore(this.yearStart) || taskStart.isAfter(this.yearEnd)){
          return
        }

        validTasks.push(t)
      })

      // 按项目分组顶层任务（parent_id === 0）
      const topLevelTasks = validTasks.filter(t => t.parent_id === 0)

      topLevelTasks.forEach(t=>{
        if(!map.has(t.project_id)){
          const p=this.cacheProjects.find(x=>x.id==t.project_id)
          if(!p) return
          map.set(t.project_id,{
            id:p.id,
            name:p.name,
            tasks:[]
          })
        }
        map.get(t.project_id).tasks.push(t)
      })

      const result=[]
      let top=0

      map.forEach(project=>{

        let rowIndex=0
        const flat=[]

        // 递归构建任务树
        const buildTaskTree = (parentId, level, parentKey = '') => {
          const children = validTasks.filter(t => t.parent_id === parentId)

          children.forEach(task => {
            const s=$A.dayjs(task.start_at)
            const e=$A.dayjs(task.end_at)

            // 计算是否超期
            const now=$A.dayjs()
            const overdue=!task.complete_at && e.isBefore(now,'day')

            // 计算直接子任务数量
            const directChildren = validTasks.filter(t => t.parent_id === task.id)
            const subCount = directChildren.length

            // 生成唯一渲染key
            const renderKey = parentKey ? `${parentKey}-${task.id}` : `${task.id}`

            // 添加当前任务
            flat.push({
              ...task,
              overdue,
              _renderKey: renderKey,
              _rowIndex: rowIndex++,
              _startOffset: s.diff(this.yearStart,'day'),
              _duration: e.diff(s,'day')+1,
              _subCount: subCount,
              _level: level,
              _isSubtask: level > 0
            })

            // 如果展开，递归添加子任务
            if(this.expandedTasks.includes(task.id) && subCount > 0){
              buildTaskTree(task.id, level + 1, renderKey)
            }
          })
        }

        // 从项目的顶层任务开始构建（parent_id === 0）
        project.tasks.forEach(task => {
          buildTaskTree(task.id, 0, '')
          // 需要先添加顶层任务本身
        })

        // 重新实现：先处理顶层任务
        rowIndex = 0
        flat.length = 0

        project.tasks.forEach(topTask => {
          const s=$A.dayjs(topTask.start_at)
          const e=$A.dayjs(topTask.end_at)
          const now=$A.dayjs()
          const overdue=!topTask.complete_at && e.isBefore(now,'day')
          const directChildren = validTasks.filter(t => t.parent_id === topTask.id)
          const subCount = directChildren.length

          // 添加顶层任务
          flat.push({
            ...topTask,
            overdue,
            _renderKey: `${topTask.id}`,
            _rowIndex: rowIndex++,
            _startOffset: s.diff(this.yearStart,'day'),
            _duration: e.diff(s,'day')+1,
            _subCount: subCount,
            _level: 0,
            _isSubtask: false
          })

          // 如果展开，递归添加子任务
          if(this.expandedTasks.includes(topTask.id) && subCount > 0){
            buildTaskTree(topTask.id, 1, `${topTask.id}`)
          }
        })

        const height=Math.max(rowIndex*this.rowHeight, this.rowHeight)

        result.push({
          ...project,
          flatTasks:flat,
          height,
          _top:top
        })

        top+=height
      })

      return result
    },

    // 总高度
    totalHeight(){
      return this.projects.reduce((a,b)=>a+b.height,0)
    },

    // 虚拟滚动可视区域
    visibleProjects(){
      const buffer=500
      const viewportHeight = this.$refs.contentScroll?.clientHeight || window.innerHeight
      const min=this.scrollTop-buffer
      const max=this.scrollTop+viewportHeight+buffer

      return this.projects.filter(p=>
        p._top+p.height>min &&
        p._top<max
      )
    }

  },

  mounted(){
    this.scrollToToday()
    window.addEventListener('mousemove',this.onMouseMove)
    window.addEventListener('mouseup',this.stopDrag)
    window.addEventListener('mouseup',this.stopMilestoneDrag)
    window.addEventListener('mousemove',this.onViewDragMove)
    window.addEventListener('mouseup',this.stopViewDrag)
  },

  beforeDestroy(){
    window.removeEventListener('mousemove',this.onMouseMove)
    window.removeEventListener('mouseup',this.stopDrag)
    window.removeEventListener('mouseup',this.stopMilestoneDrag)
    window.removeEventListener('mousemove',this.onViewDragMove)
    window.removeEventListener('mouseup',this.stopViewDrag)
    if(this.inertiaAnimationId){
      cancelAnimationFrame(this.inertiaAnimationId)
    }
  },

  methods:{

    // 展开/收起子任务
    toggleSubtasks(task){
      const index = this.expandedTasks.indexOf(task.id)
      if(index > -1){
        // 已展开，收起
        this.expandedTasks.splice(index, 1)
      }else{
        // 未展开，展开
        this.expandedTasks.push(task.id)
      }
    },

    // 选择日期
    selectDate(date){
      if(this.selectedDate === date){
        // 再次点击取消选中
        this.selectedDate = null
      }else{
        this.selectedDate = date
      }
    },

    // ==============================
    // 左侧滚轮：缩放行高
    // ==============================
    onLeftWheel(e){
      const delta=e.deltaY>0?-5:5
      this.rowHeight=Math.max(40,
        Math.min(150,this.rowHeight+delta)
      )
    },

    // ==============================
    // 右侧滚轮：缩放时间轴
    // ==============================
    onRightWheel(e){

      const container=e.currentTarget
      const rect=container.getBoundingClientRect()

      // 鼠标在容器中的位置
      const mouseX=e.clientX-rect.left

      // 当前滚动比例
      const ratio=(this.$refs.contentScroll.scrollLeft+mouseX)
        /this.totalWidth

      // 调整日宽度
      const delta=e.deltaY>0?-2:2
      this.dayWidth=Math.max(15,
        Math.min(120,this.dayWidth+delta)
      )

      // 下一帧更新滚动位置（围绕鼠标缩放）
      this.$nextTick(()=>{
        const newScroll=
          ratio*this.totalWidth-mouseX

        this.$refs.contentScroll.scrollLeft=newScroll
        this.$refs.headerScroll.scrollLeft=newScroll
      })
    },

    // 内容滚动同步到头部
    onContentScroll(e){
      if(this.syncingScroll) return

      this.syncingScroll = true
      this.scrollTop = e.target.scrollTop
      this.scrollLeft = e.target.scrollLeft

      // 同步 header 的滚动位置
      if(this.$refs.headerScroll){
        this.$refs.headerScroll.scrollLeft = e.target.scrollLeft
      }

      requestAnimationFrame(() => {
        this.syncingScroll = false
      })
    },

    // 滚动到今天
    scrollToToday(){
      this.$nextTick(()=>{
        const today=$A.dayjs().diff(this.yearStart,'day')
        const scroll=this.$refs.contentScroll
        if(scroll){
          const targetScroll = today*this.dayWidth - scroll.clientWidth/2
          scroll.scrollLeft = Math.max(0, targetScroll)
        }
      })
    },

    // 任务样式
    getTaskStyle(task){
      // 使用任务的颜色或默认颜色
      let bgColor=task.color||'#5b8cff'
      let textColor='#fff'

      if(task.complete_at){
        bgColor='#d9d9d9'
        textColor='#999'
      }else if(task.overdue){
        bgColor='#ff4d4f'
      }

      // 如果正在拖拽这个任务，使用预览值
      let startOffset = task._startOffset
      let duration = task._duration

      if(this.dragPreview && this.dragPreview.taskId === task.id){
        startOffset = this.dragPreview.startOffset
        duration = this.dragPreview.duration
      }

      // 根据层级计算缩进（每层缩进20px）
      const leftIndent = task._level * 20

      return{
        position:'absolute',
        left:(startOffset*this.dayWidth + leftIndent)+'px',
        width:(duration*this.dayWidth-4-leftIndent)+'px',
        top:task._rowIndex*this.rowHeight+8+'px',
        height:this.rowHeight-16+'px',
        backgroundColor:bgColor,
        color:textColor
      }
    },

    // 获取任务的里程碑列表
    getMilestones(task){
      if(!task.milestones || !Array.isArray(task.milestones)){
        return []
      }
      // 过滤出在任务时间范围内的里程碑，并按日期排序
      const taskStart = $A.dayjs(task.start_at)
      const taskEnd = $A.dayjs(task.end_at)
      return task.milestones
        .filter(m => {
          const mDate = $A.dayjs(m.date)
          return (mDate.isAfter(taskStart) || mDate.isSame(taskStart)) &&
                 (mDate.isBefore(taskEnd) || mDate.isSame(taskEnd))
        })
        .sort((a, b) => $A.dayjs(a.date).diff($A.dayjs(b.date)))
    },

    // 获取任务分段（根据里程碑分割）
    getTaskSegments(task){
      const milestones = this.getMilestones(task)
      if(milestones.length === 0){
        // 没有里程碑，返回单个分段
        return [{
          startDate: task.start_at,
          endDate: task.end_at,
          color: task.color || '#E3EAFD',
          milestone: null
        }]
      }

      const segments = []
      const taskStart = $A.dayjs(task.start_at)
      const taskEnd = $A.dayjs(task.end_at)

      // 第一段：任务开始到第一个里程碑
      segments.push({
        startDate: task.start_at,
        endDate: milestones[0].date,
        color: milestones[0].color || '#4A90E2',
        milestone: milestones[0]
      })

      // 中间段：里程碑之间
      for(let i = 0; i < milestones.length - 1; i++){
        const segmentStart = $A.dayjs(milestones[i].date).add(1, 'day')
        const segmentEnd = $A.dayjs(milestones[i + 1].date)

        // 只有当两个里程碑之间有间隔时才创建分段
        if(segmentEnd.isAfter(segmentStart) || segmentEnd.isSame(segmentStart)){
          segments.push({
            startDate: segmentStart.format('YYYY-MM-DD'),
            endDate: milestones[i + 1].date,
            color: milestones[i + 1].color || '#F5A623',
            milestone: milestones[i + 1]
          })
        }
      }

      // 最后一段：最后一个里程碑到任务结束（Final段）
      const lastMilestone = milestones[milestones.length - 1]
      const lastMilestoneDate = $A.dayjs(lastMilestone.date)
      const finalSegmentStart = lastMilestoneDate.add(1, 'day')

      // 只要最后里程碑不是任务结束日期，就添加Final段
      if(finalSegmentStart.isBefore(taskEnd) || finalSegmentStart.isSame(taskEnd)){
        // 使用任务的 final_milestone_color，如果没有则使用默认颜色
        const finalColor = task.final_milestone_color || task.color || this.finalSegmentColor
        const finalName = task.final_milestone_name || 'Final'

        segments.push({
          startDate: finalSegmentStart.format('YYYY-MM-DD'),
          endDate: task.end_at,
          color: finalColor,
          milestone: {
            name: finalName,
            date: task.end_at,
            color: finalColor
          },
          isFinal: true  // 标记这是Final段
        })
      }

      return segments
    },

    // 获取任务包装器样式
    getTaskWrapperStyle(task){
      if(!task.start_at || !task.end_at){
        return { display:'none' }
      }

      let startOffset = task._startOffset
      let duration = task._duration

      if(this.dragPreview && this.dragPreview.taskId === task.id){
        startOffset = this.dragPreview.startOffset
        duration = this.dragPreview.duration
      }

      const leftIndent = task._level * 20

      return{
        position:'absolute',
        left:(startOffset*this.dayWidth + leftIndent)+'px',
        width:(duration*this.dayWidth-4-leftIndent)+'px',
        top:task._rowIndex*this.rowHeight+8+'px',
        height:this.rowHeight-16+'px',
      }
    },

    // 获取分段样式
    getSegmentStyle(segment){
      const segStart = $A.dayjs(segment.startDate)
      const segEnd = $A.dayjs(segment.endDate)
      const duration = segEnd.diff(segStart, 'day') + 1

      return{
        backgroundColor: segment.color,
        width: `${duration * this.dayWidth}px`,
        minWidth: `${duration * this.dayWidth}px`,
        display: 'inline-flex',
        height: '100%',
        position: 'relative'
      }
    },

    // 计算里程碑分界点位置
    getMilestoneDividerStyle(task, milestone){
      const taskStart = $A.dayjs(task.start_at)
      const milestoneDate = $A.dayjs(milestone.date)
      const offsetDays = milestoneDate.diff(taskStart, 'day') + 1
      const leftPx = offsetDays * this.dayWidth

      return {
        left: `${leftPx}px`,
        backgroundColor: milestone.color || '#4A90E2'
      }
    },

    // 打开任务详情
    openTask(task){
      this.$store.dispatch("openTask", task)
    },

    // =============================
    // 拖拽逻辑
    // =============================
    startDrag(task,e){
      // 阻止事件冒泡到 drag-layer
      e.stopPropagation()

      // 只阻止子任务展开按钮，允许点击任务标题拖拽
      if(e.target.closest('.subtask-toggle')){
        return
      }

      this.dragTask=task
      this.resizeMode=null
      this.dragStartX=e.clientX
      this.originalStart=task._startOffset
      this.originalDuration=task._duration

      // 初始化拖拽预览
      this.dragPreview = {
        taskId: task.id,
        startOffset: task._startOffset,
        duration: task._duration
      }
    },

    startResize(task,mode,e){
      this.dragTask=task
      this.resizeMode=mode
      this.dragStartX=e.clientX
      this.originalStart=task._startOffset
      this.originalEnd=task._startOffset+task._duration
      this.originalDuration=task._duration

      // 初始化拖拽预览
      this.dragPreview = {
        taskId: task.id,
        startOffset: task._startOffset,
        duration: task._duration
      }
    },

    onMouseMove(e){
      if(this.milestoneDragTask){
        this.onMilestoneMove(e)
        return
      }

      if(!this.dragTask) return

      const dx=e.clientX-this.dragStartX
      const dayDelta=Math.round(dx/this.dayWidth)
      const maxDays = this.visibleDays.length

      if(this.resizeMode==='left'){
        const newStart=this.originalStart+dayDelta
        const diff=this.originalEnd-newStart
        if(diff>=1 && newStart>=0){
          this.dragPreview.startOffset=newStart
          this.dragPreview.duration=diff
        }
      }
      else if(this.resizeMode==='right'){
        const newEnd=this.originalEnd+dayDelta
        const diff=newEnd-this.originalStart
        if(diff>=1 && newEnd<=maxDays){
          this.dragPreview.duration=diff
        }
      }
      else{
        // 拖拽移动
        const newStart = this.originalStart+dayDelta
        const newEnd = newStart + this.originalDuration
        if(newStart>=0 && newEnd<=maxDays){
          this.dragPreview.startOffset = newStart
        }
      }
    },

    stopDrag(){
      if(!this.dragTask) return

      // 检查位置或大小是否真的改变了
      const hasChanged =
        this.dragPreview.startOffset !== this.originalStart ||
        this.dragPreview.duration !== this.originalDuration

      // 只有真正改变了才发送更新事件
      if(hasChanged){
        const newStart=this.yearStart
          .add(this.dragPreview.startOffset,'day')
          .format('YYYY-MM-DD')

        const newEnd=this.yearStart
          .add(
            this.dragPreview.startOffset+
            this.dragPreview.duration-1,
            'day'
          )
          .format('YYYY-MM-DD')

        this.$emit('update-task',{
          id:this.dragTask.id,
          start_at:newStart,
          end_at:newEnd
        })
      }

      this.dragTask=null
      this.dragPreview=null
    },

    // =============================
    // 里程碑拖拽逻辑
    // =============================
    startMilestoneDrag(task, milestoneIndex, e){
      e.stopPropagation()

      this.milestoneDragTask = task
      this.milestoneDragIndex = milestoneIndex
      this.milestoneDragStartX = e.clientX

      const milestone = this.getMilestones(task)[milestoneIndex]
      this.milestoneOriginalDate = milestone.date
    },

    onMilestoneMove(e){
      if(!this.milestoneDragTask) return

      const dx = e.clientX - this.milestoneDragStartX
      const dayDelta = Math.round(dx / this.dayWidth)

      if(dayDelta === 0) return

      const task = this.milestoneDragTask
      const milestones = this.getMilestones(task)
      const milestone = milestones[this.milestoneDragIndex]

      const newDate = $A.dayjs(this.milestoneOriginalDate).add(dayDelta, 'day')
      const taskStart = $A.dayjs(task.start_at)
      const taskEnd = $A.dayjs(task.end_at)

      // 检查边界：不能超出任务范围，且不能到达结束日期（Final的位置）
      if(newDate.isBefore(taskStart) || newDate.isAfter(taskEnd) || newDate.isSame(taskEnd)){
        return
      }

      // 检查与相邻里程碑的冲突
      if(this.milestoneDragIndex > 0){
        const prevMilestone = milestones[this.milestoneDragIndex - 1]
        const prevDate = $A.dayjs(prevMilestone.date)
        if(newDate.isBefore(prevDate) || newDate.isSame(prevDate)){
          return
        }
      }
      if(this.milestoneDragIndex < milestones.length - 1){
        const nextMilestone = milestones[this.milestoneDragIndex + 1]
        const nextDate = $A.dayjs(nextMilestone.date)
        if(newDate.isAfter(nextDate) || newDate.isSame(nextDate)){
          return
        }
      }

      // 更新里程碑日期（临时预览）
      milestone.date = newDate.format('YYYY-MM-DD')
      this.$forceUpdate()
    },

    stopMilestoneDrag(){
      if(!this.milestoneDragTask) return

      const task = this.milestoneDragTask
      const milestones = this.getMilestones(task)
      const milestone = milestones[this.milestoneDragIndex]

      // 检查日期是否真的改变了
      if(milestone.date !== this.milestoneOriginalDate){
        // 更新任务的里程碑数据
        const updatedMilestones = task.milestones.map(m => {
          if(m.name === milestone.name && m.date === this.milestoneOriginalDate){
            return { ...m, date: milestone.date }
          }
          return m
        })

        // 发送更新请求
        this.$store.dispatch("taskUpdate", {
          task_id: task.id,
          milestones: updatedMilestones
        }).then(() => {
          $A.messageSuccess('里程碑日期已更新')
        }).catch(({msg}) => {
          $A.modalError(msg)
          // 恢复原始日期
          milestone.date = this.milestoneOriginalDate
          this.$forceUpdate()
        })
      }

      this.milestoneDragTask = null
      this.milestoneDragIndex = null
      this.milestoneOriginalDate = null
    },

    // =============================
    // 视图拖拽逻辑（拖拽移动整个视图）
    // =============================
    startViewDrag(e){
      // 如果正在拖任务，禁止视图拖拽
      if(this.dragTask) return

      // 如果点在任务条上，也不要拖视图
      if(e.target.closest('.task-bar-wrapper')) return
      if(e.target.closest('.task-bar-segment')) return

      this.isDraggingView = true
      this.viewDragStartX = e.clientX
      this.viewDragStartY = e.clientY
      this.viewScrollStartX = this.$refs.contentScroll.scrollLeft
      this.viewScrollStartY = this.$refs.contentScroll.scrollTop
      this.viewDragLastX = e.clientX
      this.viewDragLastY = e.clientY
      this.viewDragLastTime = Date.now()
      this.viewDragVelocityX = 0
      this.viewDragVelocityY = 0

      // 取消惯性动画
      if(this.inertiaAnimationId){
        cancelAnimationFrame(this.inertiaAnimationId)
        this.inertiaAnimationId = null
      }

      // 改变鼠标样式
      document.body.style.cursor = 'grabbing'
      document.body.style.userSelect = 'none'
    },

    onViewDragMove(e){
      if(!this.isDraggingView) return

      const dx = this.viewDragStartX - e.clientX
      const dy = this.viewDragStartY - e.clientY

      // 更新滚动位置
      this.$refs.contentScroll.scrollLeft = this.viewScrollStartX + dx
      this.$refs.contentScroll.scrollTop = this.viewScrollStartY + dy

      // 计算速度（用于惯性滚动）
      const now = Date.now()
      const dt = now - this.viewDragLastTime
      if(dt > 0){
        this.viewDragVelocityX = (e.clientX - this.viewDragLastX) / dt * 16 // 转换为每帧速度
        this.viewDragVelocityY = (e.clientY - this.viewDragLastY) / dt * 16
      }

      this.viewDragLastX = e.clientX
      this.viewDragLastY = e.clientY
      this.viewDragLastTime = now
    },

    stopViewDrag(){
      if(!this.isDraggingView) return

      this.isDraggingView = false
      document.body.style.cursor = ''
      document.body.style.userSelect = ''

      // 启动惯性滚动
      const velocityThreshold = 0.5
      if(Math.abs(this.viewDragVelocityX) > velocityThreshold ||
         Math.abs(this.viewDragVelocityY) > velocityThreshold){
        this.startInertiaScroll()
      }
    },

    startInertiaScroll(){
      const friction = 0.95 // 摩擦系数，越小停得越快
      const minVelocity = 0.1 // 最小速度阈值

      const animate = () => {
        const el = this.$refs.contentScroll
        if(!el) return

        // 计算边界
        const maxX = el.scrollWidth - el.clientWidth
        const maxY = el.scrollHeight - el.clientHeight

        // 应用速度并限制边界
        const newScrollLeft = el.scrollLeft - this.viewDragVelocityX
        const newScrollTop = el.scrollTop - this.viewDragVelocityY

        el.scrollLeft = Math.max(0, Math.min(maxX, newScrollLeft))
        el.scrollTop = Math.max(0, Math.min(maxY, newScrollTop))

        // 如果到达边界，停止该方向的速度
        if(el.scrollLeft === 0 || el.scrollLeft === maxX){
          this.viewDragVelocityX = 0
        }
        if(el.scrollTop === 0 || el.scrollTop === maxY){
          this.viewDragVelocityY = 0
        }

        // 应用摩擦力
        this.viewDragVelocityX *= friction
        this.viewDragVelocityY *= friction

        // 检查是否应该停止
        if(Math.abs(this.viewDragVelocityX) > minVelocity ||
           Math.abs(this.viewDragVelocityY) > minVelocity){
          this.inertiaAnimationId = requestAnimationFrame(animate)
        }else{
          this.inertiaAnimationId = null
        }
      }

      this.inertiaAnimationId = requestAnimationFrame(animate)
    }

  }

}
</script>

<style scoped>
.calendar-year-view{
